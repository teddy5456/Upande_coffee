{
 "creation": "2026-04-10 00:00:00.000000",
 "custom_format": 0,
 "default_print_language": "en",
 "disabled": 0,
 "doc_type": "Delivery Note",
 "doctype": "Print Format",
 "font": "Default",
 "module": "Coffee Harvest",
 "modified": "2026-04-10 00:00:00.000000",
 "modified_by": "Administrator",
 "name": "Coffee Delivery Note",
 "owner": "Administrator",
 "print_format_builder": 0,
 "print_format_type": "Jinja",
 "show_section_headings": 0,
 "standard": "Yes",
 "html": "{% set company_abbr = doc.company.split()[-1] if doc.company else '' %}\n<style>\n  .cof-pf { font-family: Arial, sans-serif; font-size: 12px; color: #1a1a1a; padding: 16px; }\n  .cof-pf h2 { margin: 0 0 2px; font-size: 22px; color: #2d6a3f; }\n  .cof-pf .meta-label { font-size: 10px; color: #777; text-transform: uppercase; letter-spacing: .4px; }\n  .cof-pf table { border-collapse: collapse; width: 100%; }\n  .cof-pf .items-table th { background: #2d6a3f; color: #fff; padding: 6px 8px; text-align: left; font-size: 11px; }\n  .cof-pf .items-table td { padding: 5px 8px; border-bottom: 1px solid #e8e8e8; }\n  .cof-pf .items-table tr:nth-child(even) td { background: #f8faf8; }\n  .cof-pf .transport-box { border: 1px solid #2d6a3f; border-radius: 4px; padding: 10px 14px; margin: 12px 0; background: #f4faf5; }\n  .cof-pf .transport-box h4 { margin: 0 0 8px; color: #2d6a3f; font-size: 12px; text-transform: uppercase; letter-spacing: .5px; }\n  .cof-pf .transport-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4px 24px; }\n  .cof-pf .tg-item { display: flex; justify-content: space-between; padding: 2px 0; border-bottom: 1px dashed #cde5cf; }\n  .cof-pf .tg-val { font-weight: 600; }\n  .cof-pf .divider { border: none; border-top: 1px solid #ddd; margin: 12px 0; }\n  .cof-pf .totals-table td { padding: 4px 8px; }\n  .cof-pf .grand-total td { font-weight: 700; font-size: 14px; border-top: 2px solid #2d6a3f; padding-top: 8px; }\n  .cof-pf .sig-row { margin-top: 40px; display: flex; gap: 32px; }\n  .cof-pf .sig-box { flex: 1; border-top: 1px solid #333; padding-top: 6px; font-size: 11px; color: #555; }\n</style>\n\n<div class=\"cof-pf\">\n  <!-- Header -->\n  <table style=\"margin-bottom:16px\">\n    <tr>\n      <td style=\"width:55%\">\n        <h2>{{ doc.company }}</h2>\n        {% if doc.company_address %}<div style=\"color:#555;font-size:11px\">{{ doc.company_address }}</div>{% endif %}\n      </td>\n      <td style=\"text-align:right\">\n        <div style=\"font-size:18px;font-weight:700;color:#2d6a3f\">DELIVERY NOTE</div>\n        <div style=\"margin-top:4px\">\n          <span class=\"meta-label\">No.</span> <strong>{{ doc.name }}</strong>\n        </div>\n        <div><span class=\"meta-label\">Date:</span> {{ frappe.format_date(doc.posting_date) }}</div>\n        {% if doc.lr_no %}<div><span class=\"meta-label\">LR No:</span> {{ doc.lr_no }}</div>{% endif %}\n      </td>\n    </tr>\n  </table>\n\n  <hr class=\"divider\">\n\n  <!-- Customer / Delivery info -->\n  <table style=\"margin-bottom:12px\">\n    <tr>\n      <td style=\"width:50%;vertical-align:top\">\n        <div class=\"meta-label\">Customer</div>\n        <div style=\"font-weight:600;font-size:13px\">{{ doc.customer_name or doc.customer }}</div>\n        {% if doc.customer_address %}<div style=\"color:#555;font-size:11px\">{{ doc.customer_address }}</div>{% endif %}\n      </td>\n      <td style=\"width:50%;text-align:right;vertical-align:top\">\n        {% if doc.get('custom_farm') %}<div><span class=\"meta-label\">Farm:</span> {{ doc.custom_farm }}</div>{% endif %}\n        {% if doc.get('custom_business_unit') %}<div><span class=\"meta-label\">Business Unit:</span> {{ doc.custom_business_unit }}</div>{% endif %}\n        {% if doc.get('custom_delivery_type') %}<div><span class=\"meta-label\">Type:</span> {{ doc.custom_delivery_type }}</div>{% endif %}\n      </td>\n    </tr>\n  </table>\n\n  <!-- Transport details (Coffee Dispatch only) -->\n  {% if doc.get('custom_delivery_type') == 'Coffee Dispatch' %}\n  <div class=\"transport-box\">\n    <h4>Transport Details</h4>\n    <div class=\"transport-grid\">\n      <div class=\"tg-item\"><span>Driver Name</span><span class=\"tg-val\">{{ doc.get('custom_coffee_driver_name') or '—' }}</span></div>\n      <div class=\"tg-item\"><span>Number Plate</span><span class=\"tg-val\">{{ doc.get('custom_coffee_number_plate') or '—' }}</span></div>\n      <div class=\"tg-item\"><span>Transporter</span><span class=\"tg-val\">{{ doc.get('custom_coffee_transporter') or '—' }}</span></div>\n      <div class=\"tg-item\"><span>Seal / Container No.</span><span class=\"tg-val\">{{ doc.get('custom_coffee_seal_number') or '—' }}</span></div>\n    </div>\n  </div>\n  {% endif %}\n\n  <!-- Items -->\n  <table class=\"items-table\" style=\"margin-bottom:14px\">\n    <thead>\n      <tr>\n        <th>#</th>\n        <th>Item / Description</th>\n        <th style=\"text-align:right\">Qty</th>\n        <th>UOM</th>\n        <th style=\"text-align:right\">Rate</th>\n        <th style=\"text-align:right\">Amount</th>\n      </tr>\n    </thead>\n    <tbody>\n      {% for item in doc.items %}\n      <tr>\n        <td>{{ loop.index }}</td>\n        <td>\n          <strong>{{ item.item_name }}</strong>\n          {% if item.description and item.description != item.item_name %}\n          <br><span style=\"font-size:10px;color:#666\">{{ item.description | truncate(120) }}</span>\n          {% endif %}\n          {% if item.batch_no %}<br><span style=\"font-size:10px;color:#888\">Batch: {{ item.batch_no }}</span>{% endif %}\n        </td>\n        <td style=\"text-align:right\">{{ item.qty | int if item.qty == item.qty | int else item.qty }}</td>\n        <td>{{ item.uom }}</td>\n        <td style=\"text-align:right\">{{ '{:,.2f}'.format(item.rate or 0) }}</td>\n        <td style=\"text-align:right\">{{ '{:,.2f}'.format(item.amount or 0) }}</td>\n      </tr>\n      {% endfor %}\n    </tbody>\n  </table>\n\n  <!-- Totals -->\n  <table style=\"width:100%;margin-bottom:20px\">\n    <tr>\n      <td style=\"width:60%\"></td>\n      <td>\n        <table class=\"totals-table\" style=\"width:100%\">\n          <tr><td>Net Total</td><td style=\"text-align:right\">{{ '{:,.2f}'.format(doc.total or 0) }}</td></tr>\n          {% if doc.total_taxes_and_charges %}\n          <tr><td>Taxes &amp; Charges</td><td style=\"text-align:right\">{{ '{:,.2f}'.format(doc.total_taxes_and_charges or 0) }}</td></tr>\n          {% endif %}\n          <tr class=\"grand-total\">\n            <td>Grand Total ({{ doc.currency }})</td>\n            <td style=\"text-align:right\">{{ '{:,.2f}'.format(doc.grand_total or 0) }}</td>\n          </tr>\n        </table>\n      </td>\n    </tr>\n  </table>\n\n  {% if doc.terms %}\n  <div style=\"font-size:11px;color:#555;margin-bottom:16px\">\n    <div class=\"meta-label\" style=\"margin-bottom:4px\">Terms &amp; Conditions</div>\n    <div>{{ doc.terms }}</div>\n  </div>\n  {% endif %}\n\n  <!-- Signatures -->\n  <div class=\"sig-row\">\n    <div class=\"sig-box\">Authorised by ({{ doc.company }})</div>\n    <div class=\"sig-box\">Received by (Customer)</div>\n    <div class=\"sig-box\">Date Received</div>\n  </div>\n</div>"
}
